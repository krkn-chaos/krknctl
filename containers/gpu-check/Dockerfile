# Use Fedora minimal base image
FROM registry.fedoraproject.org/fedora-minimal:41

# Install necessary packages for GPU detection
RUN microdnf install -y \
    bash \
    pciutils \
    lshw \
    util-linux \
    coreutils \
    && microdnf clean all

# Copy the GPU check script
COPY gpu-check.sh /usr/local/bin/gpu-check.sh

# Make the script executable
RUN chmod +x /usr/local/bin/gpu-check.sh

# Set the script as the entrypoint
ENTRYPOINT ["/usr/local/bin/gpu-check.sh"]


