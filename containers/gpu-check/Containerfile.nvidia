# Generated by Claude Code
# NVIDIA GPU Detection Container
FROM registry.fedoraproject.org/fedora-minimal:40

# Install necessary packages for NVIDIA GPU detection
RUN microdnf install -y \
    bash \
    pciutils \
    lshw \
    util-linux \
    coreutils \
    # NVIDIA-specific packages
    mesa-vulkan-drivers \
    vulkan-loader \
    vulkan-tools \
    # Additional tools for NVIDIA detection
    glx-utils \
    && microdnf clean all

# Copy the GPU check script
COPY gpu-check.sh /usr/local/bin/gpu-check.sh

# Make the script executable
RUN chmod +x /usr/local/bin/gpu-check.sh

# Set the script as the entrypoint
ENTRYPOINT ["/usr/local/bin/gpu-check.sh"]