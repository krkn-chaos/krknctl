# Apple Silicon GPU Detection Container
FROM registry.fedoraproject.org/fedora-minimal:40

# Install dnf first, then all packages
RUN microdnf install -y dnf && microdnf clean all

# Install necessary packages for Apple Silicon GPU detection
RUN dnf -y install \
    bash \
    pciutils \
    lshw \
    util-linux \
    coreutils \
    dnf-plugins-core \
    vulkan-loader-devel \
    vulkan-headers \
    vulkan-tools \
    vulkan-loader \
    glslc \
    && dnf clean all

# Install Apple Silicon specific patched Mesa drivers
RUN dnf -y install 'dnf5-command(copr)' \
&& dnf -y copr enable slp/mesa-krunkit fedora-40-aarch64 \
    && dnf -y downgrade mesa-vulkan-drivers --repo=copr:copr.fedorainfracloud.org:slp:mesa-krunkit \
    && dnf clean all

# Copy the GPU check script
COPY gpu-check.sh /usr/local/bin/gpu-check.sh

# Make the script executable
RUN chmod +x /usr/local/bin/gpu-check.sh

# Set the script as the entrypoint
ENTRYPOINT ["/usr/local/bin/gpu-check.sh"]