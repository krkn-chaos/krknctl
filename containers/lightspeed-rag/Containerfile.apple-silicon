# Generated by Claude Code  
# krknctl Lightspeed RAG Container - Apple Silicon optimized - Multi-stage build
FROM registry.fedoraproject.org/fedora:40 AS builder

# Install build dependencies and Vulkan support for Apple Silicon
RUN dnf -y install dnf-plugins-core && \
    dnf -y install dnf-plugin-versionlock && \
    dnf -y install \
    python3 \
    python3-pip \
    python3-devel \
    curl \
    bash \
    tar \
    gzip \
    git \
    cmake \
    gcc \
    gcc-c++ \
    make \
    wget \
    which \
    # Vulkan support (for Apple Silicon)
    mesa-vulkan-drivers \
    vulkan-loader-devel \
    vulkan-headers \
    vulkan-tools \
    vulkan-loader \
    glslc \
    && (dnf -y copr enable slp/mesa-krunkit fedora-40-aarch64 || echo "Mesa krunkit copr not available, skipping") \
    && (dnf -y downgrade mesa-vulkan-drivers.aarch64 --repo=copr:copr.fedorainfracloud.org:slp:mesa-krunkit || echo "Mesa downgrade not available, skipping") \
    && (dnf versionlock mesa-vulkan-drivers || echo "Mesa versionlock not available, skipping") \
    && dnf clean all


# Verify glslc and GPU setup
RUN which glslc && glslc --version && \
    ls -la /usr/share/vulkan/icd.d/

# Set working directory
WORKDIR /app

# Create and activate virtual environment
RUN python3 -m venv /app/venv
ENV PATH="/app/venv/bin:$PATH"

# Copy requirements and install Python dependencies in venv
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Compile and install llama-cpp-python with Vulkan support (Apple Silicon optimized)
RUN CMAKE_ARGS="-DGGML_VULKAN=on" pip install --no-cache-dir --verbose llama-cpp-python

# Install huggingface-hub for reliable model downloads
RUN pip install --no-cache-dir huggingface-hub

# Download Llama 3.2:1B model in GGUF format using huggingface-hub
RUN mkdir -p /app/models && \
    python3 -c "import huggingface_hub; huggingface_hub.hf_hub_download(repo_id='bartowski/Llama-3.2-1B-Instruct-GGUF', filename='Llama-3.2-1B-Instruct-Q4_K_M.gguf', local_dir='/app/models', local_dir_use_symlinks=False)" && \
    ls -la /app/models/ && \
    [ $(stat -c%s /app/models/Llama-3.2-1B-Instruct-Q4_K_M.gguf) -gt 500000000 ] || (echo "Model download failed - file too small" && exit 1)

# Pre-build cached documentation index
COPY index_docs.py .
COPY krknctl_help.txt .
RUN python3 index_docs.py --build-cached-index

#############################################
# Runtime stage - minimal runtime dependencies
#############################################
FROM registry.fedoraproject.org/fedora-minimal:40 AS runtime

# Install only runtime dependencies + Vulkan support for Apple Silicon
RUN microdnf -y install \
    python3 \
    bash \
    curl \
    mesa-vulkan-drivers \
    vulkan-loader \
    && microdnf clean all

# Set working directory
WORKDIR /app

# Copy the complete virtual environment from builder
COPY --from=builder /app/venv/ /app/venv/

# Activate virtual environment for all subsequent commands
ENV PATH="/app/venv/bin:$PATH"
ENV VIRTUAL_ENV="/app/venv"

# Copy application files and pre-built model/indices from builder
COPY --from=builder /app/models/ /app/models/
COPY --from=builder /app/cached_docs/ /app/cached_docs/

# Create docs_index directory for runtime index generation
RUN mkdir -p /app/docs_index

# Copy application files
COPY rag_service.py .
COPY entrypoint.sh .
COPY index_docs.py .
COPY krknctl_help.txt .

# Make scripts executable
RUN chmod +x entrypoint.sh

# Expose port for FastAPI service
EXPOSE 8080

# Set environment variables
ENV PYTHONUNBUFFERED=1

# Run the entrypoint script
ENTRYPOINT ["./entrypoint.sh"]