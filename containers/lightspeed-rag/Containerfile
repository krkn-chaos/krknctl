# Generated by Claude Code  
# krknctl Lightspeed RAG Container with llama-cpp-python + Vulkan
FROM registry.fedoraproject.org/fedora-minimal:40

# Install system dependencies and Vulkan SDK
RUN microdnf install -y \
    python3 \
    python3-pip \
    python3-devel \
    curl \
    bash \
    tar \
    gzip \
    git \
    cmake \
    gcc \
    gcc-c++ \
    make \
    vulkan-headers \
    vulkan-loader-devel \
    vulkan-tools \
    glslang \
    shaderc \
    shaderc-devel \
    && microdnf clean all

# Set working directory
WORKDIR /app

# Copy requirements first for better Docker layer caching
COPY requirements.txt .

# Install Python dependencies
RUN pip3 install --no-cache-dir -r requirements.txt

# Compile and install llama-cpp-python with Vulkan support
RUN CMAKE_ARGS="-DGGML_VULKAN=on" pip3 install --no-cache-dir llama-cpp-python

# Download Llama 3.2:1B model in GGUF format
RUN mkdir -p /app/models && \
    curl -L -o /app/models/llama-3.2-1b-instruct-q4_0.gguf \
    "https://huggingface.co/lmstudio-community/Llama-3.2-1B-Instruct-GGUF/resolve/main/Llama-3.2-1B-Instruct-Q4_0.gguf"

# Copy application files
COPY rag_service.py .
COPY entrypoint.sh .
COPY index_docs.py .
COPY krknctl_help.txt .

# Make scripts executable
RUN chmod +x entrypoint.sh

# Create directories
RUN mkdir -p /app/docs_index /app/cached_docs

# Pre-build cached documentation index for offline/airgapped usage
RUN python3 index_docs.py --build-cached-index

# Expose port for FastAPI service
EXPOSE 8080

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV OLLAMA_HOST=0.0.0.0
ENV OLLAMA_PORT=11434

# Run the entrypoint script
ENTRYPOINT ["./entrypoint.sh"]