# Generated by Claude Code
# krknctl Lightspeed RAG Container with Ollama
FROM registry.fedoraproject.org/fedora-minimal:40

# Install system dependencies
RUN microdnf install -y \
    python3 \
    python3-pip \
    curl \
    bash \
    tar \
    gzip \
    git \
    && microdnf clean all

# Install Ollama
RUN curl -fsSL https://ollama.com/install.sh | sh

# Start Ollama server temporarily to pull model during build
RUN ollama serve & \
    OLLAMA_PID=$! && \
    sleep 5 && \
    for i in {1..30}; do \
        if curl -s http://localhost:11434/api/tags >/dev/null 2>&1; then \
            echo "Ollama server ready, pulling model..." && \
            ollama pull llama3.2:1b && \
            break; \
        fi; \
        sleep 2; \
    done && \
    kill $OLLAMA_PID && \
    wait $OLLAMA_PID 2>/dev/null || true

# Set working directory
WORKDIR /app

# Copy requirements first for better Docker layer caching
COPY requirements.txt .

# Install Python dependencies
RUN pip3 install --no-cache-dir -r requirements.txt

# Copy application files
COPY rag_service.py .
COPY entrypoint.sh .
COPY index_docs.py .
COPY krknctl_help.txt .

# Make scripts executable
RUN chmod +x entrypoint.sh

# Create directories
RUN mkdir -p /app/docs_index /app/cached_docs

# Pre-build cached documentation index for offline/airgapped usage
RUN python3 index_docs.py --build-cached-index

# Expose port for FastAPI service
EXPOSE 8080

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV OLLAMA_HOST=0.0.0.0
ENV OLLAMA_PORT=11434

# Run the entrypoint script
ENTRYPOINT ["./entrypoint.sh"]