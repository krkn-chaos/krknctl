# Generated by Claude Code  
# krknctl Lightspeed RAG Container with llama-cpp-python + Vulkan
FROM registry.fedoraproject.org/fedora-minimal:40

# Install system dependencies and try to get Vulkan SDK
RUN microdnf install -y \
    python3 \
    python3-pip \
    python3-devel \
    curl \
    bash \
    tar \
    gzip \
    git \
    cmake \
    gcc \
    gcc-c++ \
    cmake \
    ninja \
    make \
    wget \
    xz \
    && microdnf clean all

# Build glslc from source (native ARM64)
RUN export SOURCE_DIR=$(pwd)/shaderc && \
    export BUILD_DIR=$(pwd)/shaderc_build && \
    git clone https://github.com/google/shaderc $SOURCE_DIR && \
    cd $SOURCE_DIR && \
    ./utils/git-sync-deps && \
    mkdir -p $BUILD_DIR && cd $BUILD_DIR && \
    cmake -GNinja -DCMAKE_BUILD_TYPE=Release $SOURCE_DIR && \
    ninja && \
    ninja install

# Install Vulkan headers (lightweight, arch-independent)
RUN wget -q https://sdk.lunarg.com/sdk/download/1.3.296.0/linux/vulkansdk-linux-x86_64-1.3.296.0.tar.xz && \
    tar -xf vulkansdk-linux-x86_64-1.3.296.0.tar.xz && \
    cp -r 1.3.296.0/x86_64/include/* /usr/local/include/ && \
    rm -rf vulkansdk-linux-x86_64-1.3.296.0.tar.xz 1.3.296.0

# Set Vulkan environment  
ENV VULKAN_SDK=/usr/local
ENV PATH=$PATH:/usr/local/bin

# Set working directory
WORKDIR /app

# Copy requirements first for better Docker layer caching
COPY requirements.txt .

# Install Python dependencies
RUN pip3 install --no-cache-dir -r requirements.txt

RUN microdnf install -y which vulkan-loader vulkan-loader-devel
# Verify glslc is available
RUN which glslc && glslc --version

# Compile and install llama-cpp-python with Vulkan support
RUN CMAKE_ARGS="-DGGML_VULKAN=on" pip3 install --no-cache-dir --verbose llama-cpp-python

# Install huggingface-hub for reliable model downloads
RUN pip3 install --no-cache-dir huggingface-hub

# Download Llama 3.2:1B model in GGUF format using huggingface-hub
RUN mkdir -p /app/models && \
    python3 -c "
import huggingface_hub
huggingface_hub.hf_hub_download(
    repo_id='lmstudio-community/Llama-3.2-1B-Instruct-GGUF',
    filename='Llama-3.2-1B-Instruct-Q4_0.gguf',
    local_dir='/app/models',
    local_dir_use_symlinks=False
)" && \
    ls -la /app/models/ && \
    [ $(stat -c%s /app/models/Llama-3.2-1B-Instruct-Q4_0.gguf) -gt 1000000000 ] || (echo "Model download failed - file too small" && exit 1)

# Copy application files
COPY rag_service.py .
COPY entrypoint.sh .
COPY index_docs.py .
COPY krknctl_help.txt .

# Make scripts executable
RUN chmod +x entrypoint.sh

# Create directories
RUN mkdir -p /app/docs_index /app/cached_docs

# Pre-build cached documentation index for offline/airgapped usage
RUN python3 index_docs.py --build-cached-index

# Expose port for FastAPI service
EXPOSE 8080

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV OLLAMA_HOST=0.0.0.0
ENV OLLAMA_PORT=11434

# Run the entrypoint script
ENTRYPOINT ["./entrypoint.sh"]